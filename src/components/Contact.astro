---

<section id="contact" class="section-divider">
  <div class="max-w-content mx-auto px-6 py-20">
    <p class="eyebrow mb-4">// 05 contact</p>
    <h2 class="font-display text-3xl font-semibold mb-6 max-w-xl">
      Open to security engineering roles — internationally, or with vendors in Italy.
    </h2>
    <div class="flex flex-wrap items-center gap-4">
      <a
        href="mailto:hello@omardaniel.dev"
        class="font-mono text-sm px-5 py-3 bg-signal text-ink font-medium rounded-sm hover:brightness-110 transition"
      >
        Email me →
      </a>

      <div class="flex gap-3">
        <a
          href="https://www.linkedin.com/in/omarrdaniel/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="flex items-center justify-center w-11 h-11 border border-ink-border rounded-sm text-paper-muted hover:text-signal hover:border-trace transition"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.03-1.85-3.03-1.86 0-2.15 1.45-2.15 2.94v5.66H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z"/>
          </svg>
        </a>
        <a
          href="https://github.com/omarrdaniel"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="flex items-center justify-center w-11 h-11 border border-ink-border rounded-sm text-paper-muted hover:text-signal hover:border-trace transition"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.58 2 12.17c0 4.47 2.87 8.26 6.84 9.6.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.72-2.78.62-3.37-1.37-3.37-1.37-.46-1.2-1.11-1.52-1.11-1.52-.91-.64.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.3 9.3 0 0 1 5 0c1.9-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.35 4.79-4.58 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.17C22 6.58 17.52 2 12 2z"/>
          </svg>
        </a>
        <a
          href="mailto:hello@omardaniel.dev"
          aria-label="Email"
          class="flex items-center justify-center w-11 h-11 border border-ink-border rounded-sm text-paper-muted hover:text-signal hover:border-trace transition"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="2.5" y="4.5" width="19" height="15" rx="2"/>
            <path d="M3 6.5l9 6.5 9-6.5"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<footer class="max-w-content mx-auto px-6 py-10 flex justify-between font-mono text-xs text-paper-muted">
  <span>omar.daniel</span>
  <span>© {new Date().getFullYear()}</span>
</footer>
