---
// Signature element: an annotated request path, the way it would appear
// in a real edge-security architecture diagram. Client -> Edge (WAF/Bot
// Mgmt) -> CDN -> Zero Trust auth -> Origin. Each hop is labeled with the
// actual control applied there, and a pulse travels the path on load to
// suggest a live request being inspected at every layer.
const hops = [
  { id: 'client', label: 'Client', note: 'request' },
  { id: 'edge', label: 'Edge / WAF', note: 'bot mgmt · rate limit' },
  { id: 'cdn', label: 'CDN', note: 'cache · anti-DDoS' },
  { id: 'zt', label: 'Zero Trust', note: 'identity check' },
  { id: 'origin', label: 'Origin', note: 'response' },
];
---

<div class="w-full overflow-x-auto">
  <svg
    viewBox="0 0 920 200"
    class="w-full min-w-[640px] h-auto"
    role="img"
    aria-label="Diagram of a request passing through WAF, CDN, and Zero Trust identity checks before reaching the origin server"
  >
    <!-- base line -->
    <line x1="60" y1="90" x2="860" y2="90" stroke="#23324A" stroke-width="2" />

    <!-- traveling pulse -->
    <circle r="5" fill="#E8A33D">
      <animateMotion
        dur="3.2s"
        repeatCount="indefinite"
        path="M60,90 L860,90"
        keyPoints="0;1"
        keyTimes="0;1"
        calcMode="linear"
      />
    </circle>

    {hops.map((hop, i) => {
      const x = 60 + (i * 800) / (hops.length - 1);
      return (
        <g>
          <circle cx={x} cy="90" r="7" fill="#101B2D" stroke="#3D8FA8" stroke-width="2" />
          <text
            x={x}
            y="130"
            text-anchor="middle"
            class="font-display"
            fill="#E8EDF4"
            font-size="15"
            font-weight="600"
          >
            {hop.label}
          </text>
          <text
            x={x}
            y="152"
            text-anchor="middle"
            class="font-mono"
            fill="#8B9AB3"
            font-size="11"
          >
            {hop.note}
          </text>
        </g>
      );
    })}
  </svg>
</div>
