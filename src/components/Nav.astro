---
const links = [
  { href: '/#about', label: 'About' },
  { href: '/#experience', label: 'Experience' },
  { href: '/#projects', label: 'Projects' },
  { href: '/#skills', label: 'Skills' },
  { href: '/#contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-ink/90 backdrop-blur border-b border-ink-border">
  <nav class="max-w-content mx-auto flex items-center justify-between px-6 py-4">
    <a href="/#top" class="font-display font-semibold tracking-tight text-paper">
      omar<span class="text-signal">.</span>daniel
    </a>
    <ul class="hidden sm:flex gap-6 font-mono text-sm text-paper-muted">
      {links.map((link) => (
        <li>
          <a href={link.href} class="hover:text-signal transition-colors">{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>
