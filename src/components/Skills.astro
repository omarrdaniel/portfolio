---
const groups = [
  {
    label: 'Security',
    items: ['WAF', 'Zero Trust', 'SASE', 'Anti-DDoS', 'Threat Hunting', 'MITRE ATT&CK', 'AI Security'],
  },
  {
    label: 'Platforms',
    items: ['F5 Distributed Cloud', 'Cloudflare', 'Akamai', 'Palo Alto NGFW', 'Cisco', 'AWS', 'Azure'],
  },
  {
    label: 'Engineering',
    items: ['Terraform', 'CI/CD', 'Python', 'Linux', 'Git', 'Docker'],
  },
];
---

<section id="skills" class="section-divider">
  <div class="max-w-content mx-auto px-6 py-20">
    <p class="eyebrow mb-8">// 04 skills</p>
    <div class="grid sm:grid-cols-3 gap-10">
      {groups.map((group) => (
        <div>
          <h3 class="font-mono text-sm text-trace mb-4">{group.label}</h3>
          <ul class="space-y-2">
            {group.items.map((item) => (
              <li class="text-paper-muted">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
