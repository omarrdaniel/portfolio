---
import RequestTrace from './RequestTrace.astro';
---

<section id="top" class="max-w-content mx-auto px-6 pt-16 pb-20">
  <p class="eyebrow mb-4">// cloud & application security engineer</p>

  <h1 class="font-display text-4xl sm:text-6xl font-semibold leading-[1.05] tracking-tight max-w-3xl">
    I secure the path every request takes —
    <span class="text-trace">before it reaches the origin.</span>
  </h1>

  <p class="mt-6 max-w-xl text-paper-muted text-lg leading-relaxed">
    Cloud network & application security consultant. WAF, CDN, Zero Trust and SASE
    architectures for enterprise clients — plus the vendor relationships and pre-sales
    work that turn a design into a signed contract.
  </p>

  <div class="mt-8 flex flex-wrap gap-4">
    <a
      href="#projects"
      class="font-mono text-sm px-5 py-3 bg-signal text-ink font-medium rounded-sm hover:brightness-110 transition"
    >
      See case studies →
    </a>
    <a
      href="https://www.linkedin.com/in/omarrdaniel/"
      target="_blank"
      rel="noopener noreferrer"
      class="font-mono text-sm px-5 py-3 border border-ink-border text-paper rounded-sm hover:border-trace transition"
    >
      LinkedIn ↗
    </a>
  </div>

  <div class="mt-16">
    <RequestTrace />
  </div>
</section>
